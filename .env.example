# Path to your Google Cloud service-account JSON key file.
# This account authenticates all Google Vision requests (OAuth2, server-side).
#
# Setup:
#   1. In Google Cloud Console, enable the "Cloud Vision API" for your project.
#   2. Create a service account (IAM & Admin > Service Accounts).
#   3. Grant it a role that allows Vision calls (e.g. "Cloud Vision AI User",
#      or Project > Editor for quick local testing).
#   4. Create a JSON key for it and download it.
#   5. Save it as service-account.json (git-ignored) and point this var at it.
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# Optional: port for the Express vision proxy (defaults to 8787).
# PORT=8787
